# ─── Staging environment template ────────────────────────────────────────────
# Copy to .env.staging and fill in values.
# NEVER commit .env.staging to git.

# GCP configuration
GCP_PROJECT_ID=rubik-atlas
GCP_REGION=europe-west1

# GitHub repository (used by setup-environment.sh to create triggers)
GITHUB_REPO_OWNER=ajramos
GITHUB_REPO_NAME=rubik

# Cloud Build service account (optional — leave empty to use the default SA)
CLOUD_BUILD_SERVICE_ACCOUNT=

# Service configuration
ALLOWED_ORIGINS=*

# ─── VITE_* build-time variables ─────────────────────────────────────────────
# Add your VITE_* variables here as they are needed. These are injected at
# Docker build time via --build-arg and must be added to:
#   1. Dockerfile (ARG + ENV)
#   2. cloudbuild-staging.yaml (substitutions + --build-arg)
#   3. This file
#
# Example:
# VITE_API_URL=https://staging-api.example.com

# ─── Secrets (referenced by name in Secret Manager) ──────────────────────────
# Add secret names and their values here. The setup-environment.sh script
# will create them in Secret Manager. These are never embedded in the image.
#
# Example:
# MY_API_KEY=<your-staging-api-key>
