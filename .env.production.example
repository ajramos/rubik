# ─── Production environment template ─────────────────────────────────────────
# Copy to .env.production and fill in values.
# NEVER commit .env.production to git.

# GCP configuration
GCP_PROJECT_ID=rubik-atlas
GCP_REGION=europe-west1

# GitHub repository (used by setup-environment.sh to create triggers)
GITHUB_REPO_OWNER=ajramos
GITHUB_REPO_NAME=rubik

# Cloud Build service account (optional — leave empty to use the default SA)
CLOUD_BUILD_SERVICE_ACCOUNT=

# Service configuration
ALLOWED_ORIGINS=https://rubik-atlas.web.app  # Update with actual Cloud Run URL after first deploy

# ─── VITE_* build-time variables ─────────────────────────────────────────────
# Add your VITE_* variables here as they are needed.
#
# Example:
# VITE_API_URL=https://api.example.com

# ─── Secrets (referenced by name in Secret Manager) ──────────────────────────
# Add secret names and their values here.
#
# Example:
# MY_API_KEY=<your-production-api-key>
